{{- /*
─────────────────────────────────────────────────────────────────────────────
Implementation notes for this template
─────────────────────────────────────────────────────────────────────────────

Pipeline context:
  This template runs as the FINAL step of the entpoly codegen pass. By the
  time we execute, ent has already generated everything in the target
  package: client.go, *_create.go, *_update.go, *_query.go, and per-type
  predicate sub-packages (e.g. <pkg>/comment/where.go). We append a single
  file (polymorphic.go) into the same package — that is what lets us add
  typed methods to ent.Post, ent.CommentCreate, etc. without modifying
  ent's own templates.

Data shape:
  The root context (.) is *entpoly.tmplData defined in generate.go. Every
  field this template references MUST exist there; populate via
  buildTmplData. Adding a new emission means: add a field on tmplData,
  populate it in buildTmplData, then range over it here.

Nested-range scope rule (the #1 gotcha):
  Go templates do NOT scope `.` upward across nested ranges. Inside an
  inner range, `.` is the inner element and `$` is the ROOT context (not
  the outer range's element). To reference outer-range fields from an
  inner range, BIND the outer with `range $c := .Children` and use `$c`
  inside. See the "Per-child Set/Clear builder methods" and the
  resolver sections below for the working pattern. If you forget this
  and use `$.Type` to reach the outer child, the template either
  silently emits the wrong thing or errors with "can't evaluate field
  Type in type *entpoly.tmplData".

Determinism:
  Two `go generate` runs against an identical schema must produce
  byte-identical output. buildTmplData sorts every slice it populates;
  iterating MAPS in this template is forbidden (range over a sorted
  slice or a slice-of-pairs instead).

Imports:
  The import block is conditional on SubpackageImports (deduplicated by
  buildTmplData). When adding code that references a new sub-package
  ident, ensure buildTmplData adds it to the import set — otherwise
  go/format will reject the rendered file with "undefined: pkg".

Method receivers and reflection:
  We freely add methods on ent-generated types (e.g. *Post, *CommentCreate)
  because polymorphic.go is in the SAME Go package. This is the entire
  reason we live as a codegen extension, not as a runtime library.

Casts that look redundant:
  The frequent <ident>.<TypeField>(string(...)) calls (e.g.
  comment.CommentableType(string(PostMorphKey))) ARE redundant under
  Go's type system but are required because ent's enum field emits a
  named string type (comment.CommentableType) and our morph-key
  constants are a separate named string type (MorphKey). The double
  conversion lets both type identities coexist without compromising
  either side's compile-time safety.

If you add a new edge kind:
  1. Update markerAnnotation.Kind in edge.go (new constant string).
  2. Dispatch on it in preprocess.go.
  3. Add a polyState slice in state.go.
  4. Populate tmplData via buildTmplData in generate.go.
  5. Add the template section here.
  6. Add tests in entpoly/edge_test.go and edgecase_test.go AND a
     runtime test in examples/basic/runtime_test.go.

See doc.go for the full codebase layout.
*/ -}}
{{ define "file" -}}
// Code generated by entpoly. DO NOT EDIT.

package {{ .Package }}

import (
	"context"
	"fmt"
	"strconv"

	"{{ .ImportPath }}/predicate"
{{- range .SubpackageImports }}
	"{{ $.ImportPath }}/{{ . }}"
{{- end }}
)

// Compile-time silence in case strconv is never referenced (rare — only
// when no child resolver branch needs numeric ID parsing).
var _ = strconv.Atoi

// Compile-time silence in case context is never referenced (rare — only
// when no MorphOne back-refs are present in the entire graph).
var _ = context.Background

// MorphKey is a named string type for the persisted "*_type" alias of
// every parent type in a polymorphic relation. Using a named type instead
// of a raw string lets callers pass only one of the codegen-emitted
// constants (PostMorphKey, VideoMorphKey, ...), which the Go compiler
// validates — preventing typos like CommentableTypeEQ("psot").
type MorphKey string

// Morphable is implemented by every entity that may sit on the parent side
// of a polymorphic relation. Generated MorphID()/MorphKey() satisfy this.
type Morphable interface {
	MorphID() string
	MorphKey() MorphKey
}

// ─── Morph map ─────────────────────────────────────────────────────────────

// morphTypeMap maps the persisted "*_type" string to the ent type name.
// Configure aliases via entpoly.WithMorphMap(...) at codegen time.
var morphTypeMap = map[MorphKey]string{
{{- range .MorphMap }}
	{{ .Type }}MorphKey: "{{ .Type }}",
{{- end }}
}

// MorphTypeFor returns the morph key registered for an ent type name, or
// an empty string when no alias is registered.
func MorphTypeFor(typeName string) MorphKey {
	for k, v := range morphTypeMap {
		if v == typeName {
			return k
		}
	}
	return ""
}

// MorphTypeName returns the ent type name registered for a morph key, or
// an empty string when the key is unknown.
func MorphTypeName(morphKey MorphKey) string {
	return morphTypeMap[morphKey]
}

{{- /* ─── Per-parent morph-key constants ──────────────────────────── */ -}}
// Per-type morph-key constants. Use these instead of hard-coding the
// persisted string — the named MorphKey type prevents arbitrary string
// literals from being passed where a polymorphic alias is expected.
//
//	client.Comment.Query().Where(
//	    CommentCommentableIsType(PostMorphKey),  // typed: only known constants compile
//	).All(ctx)
const (
{{- range .MorphMap }}
	// {{ .Type }}MorphKey is the persisted "*_type" alias for {{ .Type }}.
	{{ .Type }}MorphKey MorphKey = "{{ .Key }}"
{{- end }}
)

{{- /* ─── Per-parent Morphable methods ─────────────────────────────── */ -}}
{{ range .MorphMap }}

// MorphID returns the string id for {{ .Type }}. Non-string ids are stringified
// via fmt.Sprint to fit the polymorphic id column.
func (e *{{ .Type }}) MorphID() string { return fmt.Sprint(e.ID) }

// MorphKey returns the persisted "*_type" alias for {{ .Type }}.
func (*{{ .Type }}) MorphKey() MorphKey { return {{ .Type }}MorphKey }
{{- end }}

{{- /* ─── Sealed parent interfaces (one per child × relation) ───── */ -}}
{{ range $c := .Children }}

// {{ $c.Type }}{{ $c.RelationCap }}Parent is the sealed interface restricting
// which types may be passed as the polymorphic parent of a {{ $c.Type }} on
// its "{{ $c.Relation }}" relation. Only types listed in the schema's
// AllowedTypes (passed to MorphTo) carry the marker method, so passing
// any other type to Set{{ $c.RelationCap }} is a compile error.
//
// This is the Go-equivalent of a sum type / discriminated union; it mirrors
// the way ent's typed enum fields restrict assignable values.
type {{ $c.Type }}{{ $c.RelationCap }}Parent interface {
	Morphable
	is{{ $c.Type }}{{ $c.RelationCap }}Parent()
}

{{- range $parent := $c.AllowedTypes }}

// is{{ $c.Type }}{{ $c.RelationCap }}Parent marks *{{ $parent }} as an
// allowed parent of {{ $c.Type }} on the "{{ $c.Relation }}" relation.
// Generated only for types listed in the schema's AllowedTypes; this is
// the entire mechanism behind the compile-time restriction.
func (*{{ $parent }}) is{{ $c.Type }}{{ $c.RelationCap }}Parent() {}
{{- end }}
{{ end }}

{{- /* ─── Per-child Set/Clear builder methods ─────────────────────── */ -}}
{{ range $c := .Children }}

// Set{{ .RelationCap }} sets the polymorphic parent on the Create builder.
// Accepts only types declared in the schema's AllowedTypes — see
// {{ .Type }}{{ .RelationCap }}Parent.
func (c *{{ .Type }}Create) Set{{ .RelationCap }}(p {{ .Type }}{{ .RelationCap }}Parent) *{{ .Type }}Create {
	return c.Set{{ .IDField }}(p.MorphID()).Set{{ .TypeField }}({{ .IDent }}.{{ .TypeField }}(string(p.MorphKey())))
}

// Set{{ .RelationCap }} sets the polymorphic parent on the Update builder.
func (u *{{ .Type }}Update) Set{{ .RelationCap }}(p {{ .Type }}{{ .RelationCap }}Parent) *{{ .Type }}Update {
	return u.Set{{ .IDField }}(p.MorphID()).Set{{ .TypeField }}({{ .IDent }}.{{ .TypeField }}(string(p.MorphKey())))
}

// Clear{{ .RelationCap }} clears the polymorphic parent on the Update builder.
func (u *{{ .Type }}Update) Clear{{ .RelationCap }}() *{{ .Type }}Update {
	return u.Clear{{ .IDField }}().Clear{{ .TypeField }}()
}

// Set{{ .RelationCap }} sets the polymorphic parent on the single-row UpdateOne.
func (u *{{ .Type }}UpdateOne) Set{{ .RelationCap }}(p {{ .Type }}{{ .RelationCap }}Parent) *{{ .Type }}UpdateOne {
	return u.Set{{ .IDField }}(p.MorphID()).Set{{ .TypeField }}({{ .IDent }}.{{ .TypeField }}(string(p.MorphKey())))
}

// Clear{{ .RelationCap }} clears the polymorphic parent on the single-row UpdateOne.
func (u *{{ .Type }}UpdateOne) Clear{{ .RelationCap }}() *{{ .Type }}UpdateOne {
	return u.Clear{{ .IDField }}().Clear{{ .TypeField }}()
}

// Set{{ .RelationCap }} sets the polymorphic parent on the Mutation.
func (m *{{ .Type }}Mutation) Set{{ .RelationCap }}(p {{ .Type }}{{ .RelationCap }}Parent) *{{ .Type }}Mutation {
	m.Set{{ .IDField }}(p.MorphID())
	m.Set{{ .TypeField }}({{ .IDent }}.{{ .TypeField }}(string(p.MorphKey())))
	return m
}

// Clear{{ .RelationCap }} clears the polymorphic parent on the Mutation.
func (m *{{ .Type }}Mutation) Clear{{ .RelationCap }}() *{{ .Type }}Mutation {
	m.Clear{{ .IDField }}()
	m.Clear{{ .TypeField }}()
	return m
}

// {{ .Type }}{{ .RelationCap }}Is returns a predicate that matches {{ .Type }}
// rows pointing at the given parent — both the id and the morph type must
// match. The parent is restricted to the AllowedTypes via the sealed
// {{ .Type }}{{ .RelationCap }}Parent interface.
//
//	client.{{ .Type }}.Query().Where({{ .Type }}{{ .RelationCap }}Is(post)).All(ctx)
func {{ .Type }}{{ .RelationCap }}Is(p {{ .Type }}{{ .RelationCap }}Parent) predicate.{{ .Type }} {
	return {{ .IDent }}.And(
		{{ .IDent }}.{{ .IDField }}EQ(p.MorphID()),
		{{ .IDent }}.{{ .TypeField }}EQ({{ .IDent }}.{{ .TypeField }}(string(p.MorphKey()))),
	)
}

// {{ .Type }}{{ .RelationCap }}IsType returns a predicate that matches
// {{ .Type }} rows whose polymorphic parent is *any instance* of the given
// morph type. Accepts only the codegen-emitted MorphKey constants.
//
//	client.{{ .Type }}.Query().
//	    Where({{ .Type }}{{ .RelationCap }}IsType(PostMorphKey)).
//	    All(ctx)
func {{ .Type }}{{ .RelationCap }}IsType(k MorphKey) predicate.{{ .Type }} {
	return {{ .IDent }}.{{ .TypeField }}EQ({{ .IDent }}.{{ .TypeField }}(string(k)))
}

// Query{{ .RelationCap }} resolves the polymorphic parent of this {{ .Type }}
// and returns it through the sealed-interface return type. The caller
// type-switches on the result to recover the concrete parent — only the
// types listed in MorphTo's AllowedTypes are possible branches.
//
// Laravel equivalent:
//
//	$commentable = $comment->commentable;  // Post | Video | null
//
// entpoly:
//
//	parent, err := comment.Query{{ .RelationCap }}(ctx)
//	if err != nil { return err }
//	switch p := parent.(type) {
{{- range .ResolveCases }}
//	case *{{ .Type }}:
//	    // use p as *{{ .Type }}
{{- end }}
//	case nil:
//	    // no parent set
//	}
//
// Returns (nil, nil) when the discriminator pair is unset. Returns a
// typed error when the persisted morph type is not in the allowed set
// (e.g. data written by a different schema version or a bypass via raw
// SQL despite the DB enum constraint).
func (c *{{ .Type }}) Query{{ .RelationCap }}(ctx context.Context) ({{ .Type }}{{ .RelationCap }}Parent, error) {
	if c.{{ .IDField }} == nil || c.{{ .TypeField }} == nil {
		return nil, nil
	}
	switch *c.{{ $c.TypeField }} {
	{{- range $rc := $c.ResolveCases }}
	case {{ $c.IDent }}.{{ $c.TypeField }}(string({{ $rc.MorphConst }})):
		{{- if eq $rc.IDGoType "int" }}
		id, err := strconv.Atoi(*c.{{ $c.IDField }})
		if err != nil {
			return nil, fmt.Errorf("entpoly: parse {{ $rc.Type }} id %q: %w", *c.{{ $c.IDField }}, err)
		}
		return New{{ $rc.Type }}Client(c.config).Get(ctx, id)
		{{- else if eq $rc.IDGoType "int64" }}
		id, err := strconv.ParseInt(*c.{{ $c.IDField }}, 10, 64)
		if err != nil {
			return nil, fmt.Errorf("entpoly: parse {{ $rc.Type }} id %q: %w", *c.{{ $c.IDField }}, err)
		}
		return New{{ $rc.Type }}Client(c.config).Get(ctx, id)
		{{- else }}
		return New{{ $rc.Type }}Client(c.config).Get(ctx, *c.{{ $c.IDField }})
		{{- end }}
	{{- end }}
	default:
		return nil, fmt.Errorf("entpoly: unknown morph type %q for {{ $c.Type }}.{{ $c.Relation }}", *c.{{ $c.TypeField }})
	}
}
{{ end }}

{{- /* ─── Holder-side typed M2M back-refs ────────────────────────── */ -}}
{{ range .Holders }}

// Query{{ .FieldCap }} returns all {{ .Target }} rows polymorphically
// attached to this {{ .HolderName }} via the {{ .Pivot }} pivot. Reads
// the pivot rows that match (holder, target-morph-key), parses the
// stringified ids, and loads the corresponding {{ .Target }} rows in a
// single follow-up query.
//
// Laravel:    $posts = $tag->posts;
// entpoly:    posts, err := tag.Query{{ .FieldCap }}(ctx)
func (h *{{ .HolderName }}) Query{{ .FieldCap }}(ctx context.Context) ([]*{{ .Target }}, error) {
	pivots, err := New{{ .Pivot }}Client(h.config).Query().
		Where(
			{{ .PivotIDent }}.{{ .HolderFKField }}EQ(h.ID),
			{{ .PivotIDent }}.{{ .PivotTypeField }}EQ({{ .PivotIDent }}.{{ .PivotTypeField }}(string({{ .TargetMorph }}))),
		).
		All(ctx)
	if err != nil {
		return nil, err
	}
	if len(pivots) == 0 {
		return []*{{ .Target }}{}, nil
	}
	{{- if eq .TargetIDGoType "int" }}
	ids := make([]int, 0, len(pivots))
	for _, p := range pivots {
		if p.{{ .PivotIDField }} == nil {
			continue
		}
		id, perr := strconv.Atoi(*p.{{ .PivotIDField }})
		if perr != nil {
			return nil, fmt.Errorf("entpoly: parse {{ .Target }} id %q in {{ .Pivot }} pivot: %w", *p.{{ .PivotIDField }}, perr)
		}
		ids = append(ids, id)
	}
	{{- else if eq .TargetIDGoType "int64" }}
	ids := make([]int64, 0, len(pivots))
	for _, p := range pivots {
		if p.{{ .PivotIDField }} == nil {
			continue
		}
		id, perr := strconv.ParseInt(*p.{{ .PivotIDField }}, 10, 64)
		if perr != nil {
			return nil, fmt.Errorf("entpoly: parse {{ .Target }} id %q in {{ .Pivot }} pivot: %w", *p.{{ .PivotIDField }}, perr)
		}
		ids = append(ids, id)
	}
	{{- else }}
	ids := make([]string, 0, len(pivots))
	for _, p := range pivots {
		if p.{{ .PivotIDField }} == nil {
			continue
		}
		ids = append(ids, *p.{{ .PivotIDField }})
	}
	{{- end }}
	return New{{ .Target }}Client(h.config).Query().Where({{ .TargetIDent }}.IDIn(ids...)).All(ctx)
}
{{ end }}

{{- /* ─── Parent-side typed back-refs (Laravel-style accessors) ──── */ -}}
{{ range .Parents }}
{{ if eq .Kind "morphOne" }}
// Query{{ .FieldCap }} returns the single {{ .Target }} polymorphically
// attached to this {{ .ParentName }} via the "{{ .MorphName }}" relation,
// or (nil, nil) when no row matches. Laravel-style accessor — equivalent
// to PHP's:
//
//	$image = $post->image;  // ← Laravel
//	img, err := post.QueryFeaturedImage(ctx)  // ← entpoly
func (p *{{ .ParentName }}) Query{{ .FieldCap }}(ctx context.Context) (*{{ .Target }}, error) {
	res, err := New{{ .Target }}Client(p.config).Query().
		Where(
			{{ .TargetIDent }}.{{ .IDField }}EQ(p.MorphID()),
			{{ .TargetIDent }}.{{ .TypeField }}EQ({{ .TargetIDent }}.{{ .TypeField }}(string(p.MorphKey()))),
		).
		First(ctx)
	if err != nil {
		// IsNotFound is the "no row" case — return (nil, nil) so the
		// caller can null-check without unwrapping the error type. Any
		// other error (driver, context cancel, ...) is propagated.
		if IsNotFound(err) {
			return nil, nil
		}
		return nil, err
	}
	return res, nil
}
{{- end }}
{{ if eq .Kind "morphMany" }}
// Query{{ .FieldCap }} returns a query builder for all {{ .Target }} rows
// polymorphically attached to this {{ .ParentName }} via the
// "{{ .MorphName }}" relation. The query is composable — chain .Where(),
// .Order(), .Limit(), .All(ctx), .First(ctx), etc.
//
//	// Laravel:    $comments = $post->comments;
//	// entpoly:    comments, _ := post.QueryComments().All(ctx)
//	//             page, _    := post.QueryComments().Limit(10).All(ctx)
func (p *{{ .ParentName }}) Query{{ .FieldCap }}() *{{ .Target }}Query {
	return New{{ .Target }}Client(p.config).Query().
		Where(
			{{ .TargetIDent }}.{{ .IDField }}EQ(p.MorphID()),
			{{ .TargetIDent }}.{{ .TypeField }}EQ({{ .TargetIDent }}.{{ .TypeField }}(string(p.MorphKey()))),
		)
}
{{- end }}
{{ end }}
