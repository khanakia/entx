	{{- end }}
	return New{{ .Target }}Client(h.config).Query().Where({{ .TargetIDent }}.IDIn(ids...)).All(ctx)
}

// Query{{ .InverseFieldCap }} returns all {{ .HolderName }} rows attached
// to this {{ .Target }} via the {{ .Pivot }} pivot. Inverse direction of
// Query{{ .FieldCap }} above — auto-generated from the holder-side
// MorphedByMany declaration so {{ .Target }} does NOT need a matching
// schema declaration.
//
// Laravel:    $tags = $post->tags;
// entpoly:    tags, err := post.Query{{ .InverseFieldCap }}(ctx)
func (p *{{ .Target }}) Query{{ .InverseFieldCap }}(ctx context.Context) ([]*{{ .HolderName }}, error) {
	pivots, err := New{{ .Pivot }}Client(p.config).Query().
		Where(
			{{ .PivotIDent }}.{{ .PivotIDField }}EQ(p.MorphID()),
			{{ .PivotIDent }}.{{ .PivotTypeField }}EQ({{ if .TypeIsEnum }}{{ .PivotIDent }}.{{ .PivotTypeField }}(string({{ .TargetMorph }})){{ else }}string({{ .TargetMorph }}){{ end }}),
		).
		All(ctx)
	if err != nil {
		return nil, err
