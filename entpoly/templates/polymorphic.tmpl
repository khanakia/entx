{{- /* Per-parent predicate constructors: <Child><Rel>On<Parent> emit
a single-statement sub-query filter — "rows whose polymorphic parent
is a <Parent> matching every passed predicate." Zero predicates =
type-only filter. When MorphTo.SoftDelete() is set AND the parent
declares the soft-delete column, an IS NULL filter on that column is
appended to the sub-query automatically. Composes with comment.Or /
And to express multi-type matches:

  comment.Or(
      ent.CommentCommentableOnPost(post.PublishedEQ(true)),
      ent.CommentCommentableOnVideo(video.ViewsGT(1000)),
  )

See docs/adr-002-where-morph-relation.md for the design. */ -}}
{{ $c := . }}
{{ range $rc := $c.ResolveCases }}
// {{ $c.Type }}{{ $c.RelationCap }}On{{ $rc.Type }} returns a predicate.{{ $c.Type }}
// matching rows whose polymorphic "{{ $c.Relation }}" parent is a
// {{ $rc.Type }} satisfying every supplied predicate. Zero predicates
// match every {{ $c.Type }} pointing at a {{ $rc.Type }}, regardless of
// the parent's columns.
//
// Laravel equivalent:
//
//	Comment::whereHasMorph('{{ $c.Relation }}', [{{ $rc.Type }}::class], fn ($q) => $q->where('approved', true))
//
// entpoly:
//
//	client.{{ $c.Type }}.Query().Where(
//	    {{ $c.Type }}{{ $c.RelationCap }}On{{ $rc.Type }}({{ $rc.IDent }}.ApprovedEQ(true)),
//	).All(ctx)
//
{{- if $rc.HasSoftDelete }}
// SoftDelete enabled: the sub-query also filters out {{ $rc.Type }} rows
// whose {{ $rc.SoftDeleteFieldCap }} is non-null, matching the read-side
// guarantees of Query{{ $c.RelationCap }} / With{{ $c.RelationCap }}.
{{- end }}
func {{ $c.Type }}{{ $c.RelationCap }}On{{ $rc.Type }}(preds ...predicate.{{ $rc.Type }}) predicate.{{ $c.Type }} {
	return predicate.{{ $c.Type }}(func(s *sql.Selector) {
		sub := sql.Select({{ $rc.IDent }}.FieldID).From(sql.Table({{ $rc.IDent }}.Table))
		for _, p := range preds {
			p(sub)
		}
		{{- if $rc.HasSoftDelete }}
		sub.Where(sql.IsNull({{ $rc.IDent }}.Field{{ $rc.SoftDeleteFieldCap }}))
		{{- end }}
		s.Where(sql.And(
			sql.EQ(s.C({{ $c.IDent }}.Field{{ $c.TypeField }}), string({{ $rc.MorphConst }})),
			sql.In(s.C({{ $c.IDent }}.Field{{ $c.IDField }}), sub),
		))
	})
}
{{ end }}

// Query{{ .RelationCap }} resolves the polymorphic parent of this {{ .Type }}
// and returns it through the sealed-interface return type. The caller
// type-switches on the result to recover the concrete parent — only the
// types listed in MorphTo's AllowedTypes are possible branches.
//
// Laravel equivalent:
//
//	$commentable = $comment->commentable;  // Post | Video | null
//
// entpoly:
//
//	parent, err := comment.Query{{ .RelationCap }}(ctx)
//	if err != nil { return err }
//	switch p := parent.(type) {
{{- range .ResolveCases }}
//	case *{{ .Type }}:
//	    // use p as *{{ .Type }}
{{- end }}
//	case nil:
//	    // no parent set
//	}
//
// Returns (nil, nil) when the discriminator pair is unset. Returns a
// typed error when the persisted morph type is not in the allowed set
// (e.g. data written by a different schema version or a bypass via raw
// SQL despite the DB enum constraint).
func (c *{{ .Type }}) Query{{ .RelationCap }}(ctx context.Context) ({{ .Type }}{{ .RelationCap }}Parent, error) {
	if c.{{ .IDField }} == nil || c.{{ .TypeField }} == nil {
		return nil, nil
	}
	switch *c.{{ $c.TypeField }} {
	{{- range $rc := $c.ResolveCases }}
	case {{ if $c.TypeIsEnum }}{{ $c.IDent }}.{{ $c.TypeField }}(string({{ $rc.MorphConst }})){{ else }}string({{ $rc.MorphConst }}){{ end }}:
		{{- if eq $rc.IDGoType "int" }}
		id, err := strconv.Atoi(*c.{{ $c.IDField }})
		if err != nil {
			return nil, fmt.Errorf("entpoly: parse {{ $rc.Type }} id %q: %w", *c.{{ $c.IDField }}, err)
		}
		{{- else if eq $rc.IDGoType "int64" }}
		id, err := strconv.ParseInt(*c.{{ $c.IDField }}, 10, 64)
		if err != nil {
			return nil, fmt.Errorf("entpoly: parse {{ $rc.Type }} id %q: %w", *c.{{ $c.IDField }}, err)
		}
		{{- else if eq $rc.IDGoType "uuid.UUID" }}
		id, err := uuid.Parse(*c.{{ $c.IDField }})
		if err != nil {
			return nil, fmt.Errorf("entpoly: parse {{ $rc.Type }} id %q: %w", *c.{{ $c.IDField }}, err)
		}
		{{- else }}
		id := *c.{{ $c.IDField }}
		{{- end }}
		{{- if $rc.HasSoftDelete }}
		// Soft-delete filter: skip parents with non-null
		// {{ $rc.SoftDeleteFieldCap }}; IsNotFound is the "soft-deleted or
		// genuinely missing" path — return (nil, nil) so the caller
		// can null-check without unwrapping the error type.
		res, qerr := New{{ $rc.Type }}Client(c.config).Query().
			Where({{ $rc.IDent }}.IDEQ(id), {{ $rc.IDent }}.{{ $rc.SoftDeleteFieldCap }}IsNil()).
			First(ctx)
		if qerr != nil {
			if IsNotFound(qerr) {
				return nil, nil
			}
			return nil, qerr
		}
		return res, nil
		{{- else }}
		return New{{ $rc.Type }}Client(c.config).Get(ctx, id)
		{{- end }}
	{{- end }}
	default:
		return nil, fmt.Errorf("entpoly: unknown morph type %q for {{ $c.Type }}.{{ $c.Relation }}", *c.{{ $c.TypeField }})
	}
}
{{ end }}

{{- /* ─── GraphQL union emission (per child × allowed parent) ───────
For every MorphTo declared with .GQL(), emit a Go-side union surface
that gqlgen recognises:

  - type alias: `type <Union> = <Child><Rel>Parent` so the sealed
    interface doubles as the GraphQL union Go type.
  - exported markers: `func (*Post) Is<Union>() {}` on every member;
    gqlgen reflects over these (it ignores unexported markers, so
    these supplement — they don't replace — the sealed interface's
    unexported marker that powers Set/Clear restriction).
