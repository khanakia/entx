	if len(pivots) == 0 {
		return []*{{ .HolderName }}{}, nil
	}
	// Pivot's holder FK is a regular ent field, NOT a stringified
	// polymorphic id — collect the typed values directly.
	{{- if eq .HolderIDGoType "int" }}
	ids := make([]int, 0, len(pivots))
	{{- else if eq .HolderIDGoType "int64" }}
	ids := make([]int64, 0, len(pivots))
	{{- else if eq .HolderIDGoType "uuid.UUID" }}
	ids := make([]uuid.UUID, 0, len(pivots))
	{{- else }}
	ids := make([]string, 0, len(pivots))
	{{- end }}
	for _, pv := range pivots {
		ids = append(ids, pv.{{ .HolderFKField }})
	}
	return New{{ .HolderName }}Client(p.config).Query().Where({{ .HolderIDent }}.IDIn(ids...)).All(ctx)
}
{{ end }}

{{- /* ─── Eager-load batching (N+1 fix) ─────────────────────────────
For every MorphTo with at least one allowed parent type, emit a
"AllWith<Rel>" method on the child's Query type that:

  1. Runs the normal child query (returns []*Child).
  2. Buckets the children by their persisted morph_type value.
  3. Fires ONE batched parent query per bucket (a single IN(...)).
  4. Returns a typed result struct mapping child.ID → parent.

Total queries: 1 + (distinct parent types in this batch). For most
list pages that is 2-3, down from N+1.

The result map key is the child's own ID Go type so the lookup is
type-safe end-to-end. The map value is the sealed parent interface,
so `case *Article:` would not compile even if accidentally present
in a type switch over the returned parents. */ -}}
{{ range $c := .Children }}
{{- if $c.ResolveCases }}

// {{ $c.Type }}{{ $c.RelationCap }}PreloadResult is the typed eager-load
// result returned by ({{ $c.Type }}Query).With{{ $c.RelationCap }}().All(ctx).
// The {{ $c.ChildPlural }} slice is the same shape
// {{ $c.Type }}Query.All(ctx) would have returned; the {{ $c.RelationCap }}
// map is keyed by {{ $c.Type }}.ID and holds each row's resolved
// polymorphic parent.
type {{ $c.Type }}{{ $c.RelationCap }}PreloadResult struct {
	{{ $c.ChildPlural }} []*{{ $c.Type }}
	{{ $c.RelationCap }} map[{{ $c.ChildIDGoType }}]{{ $c.Type }}{{ $c.RelationCap }}Parent
}

// {{ $c.Type }}{{ $c.RelationCap }}Loader is the ent-native chainable
// eager-load object returned by ({{ $c.Type }}Query).With{{ $c.RelationCap }}().
// Call .All(ctx) on it to run the batched query and receive a typed
// result. Mirrors ent's standard .WithX().All(ctx) idiom.
type {{ $c.Type }}{{ $c.RelationCap }}Loader struct {
	q *{{ $c.Type }}Query
}

// With{{ $c.RelationCap }} returns the typed eager-load chain for this query.
// Use over plain .All(ctx) on any list-page path to avoid the N+1
// problem inherent to per-row Query{{ $c.RelationCap }}(ctx) calls.
//
//	r, err := client.{{ $c.Type }}.Query().Limit(50).With{{ $c.RelationCap }}().All(ctx)
//	for _, child := range r.{{ $c.ChildPlural }} {
//	    parent := r.{{ $c.RelationCap }}[child.ID]
//	    switch p := parent.(type) {
{{- range $rc := $c.ResolveCases }}
//	    case *{{ $rc.Type }}: // typed *{{ $rc.Type }}
{{- end }}
//	    case nil: // discriminator unset on this row
//	    }
//	}
//
// Total queries: 1 (children) + N (distinct parent types in the
// batch). Compared to lazy resolution via Query{{ $c.RelationCap }}(ctx),
// which fires one parent query PER child, this is the standard
// N+1 fix.
func (q *{{ $c.Type }}Query) With{{ $c.RelationCap }}() *{{ $c.Type }}{{ $c.RelationCap }}Loader {
	return &{{ $c.Type }}{{ $c.RelationCap }}Loader{q: q}
}

// All runs the {{ $c.Type }} query and eager-loads every row's
// polymorphic "{{ $c.Relation }}" parent in batched per-type queries.
func (l *{{ $c.Type }}{{ $c.RelationCap }}Loader) All(ctx context.Context) (*{{ $c.Type }}{{ $c.RelationCap }}PreloadResult, error) {
	children, err := l.q.All(ctx)
	if err != nil {
		return nil, err
	}
	result := &{{ $c.Type }}{{ $c.RelationCap }}PreloadResult{
		{{ $c.ChildPlural }}: children,
		{{ $c.RelationCap }}: make(map[{{ $c.ChildIDGoType }}]{{ $c.Type }}{{ $c.RelationCap }}Parent, len(children)),
	}
	if len(children) == 0 {
		return result, nil
	}

	// Per-parent-type buckets — collect both the child→childlist map
	// (so we can attach the loaded parent back to every child) and
	// the list of parent IDs to feed the batched IN(...) query.
	{{- range $rc := $c.ResolveCases }}
	{{- if eq $rc.IDGoType "int" }}
	var {{ $rc.IDent }}IDs []int
	{{ $rc.IDent }}ToChildren := map[int][]*{{ $c.Type }}{}
	{{- else if eq $rc.IDGoType "int64" }}
	var {{ $rc.IDent }}IDs []int64
	{{ $rc.IDent }}ToChildren := map[int64][]*{{ $c.Type }}{}
	{{- else if eq $rc.IDGoType "uuid.UUID" }}
	var {{ $rc.IDent }}IDs []uuid.UUID
	{{ $rc.IDent }}ToChildren := map[uuid.UUID][]*{{ $c.Type }}{}
	{{- else }}
	var {{ $rc.IDent }}IDs []string
	{{ $rc.IDent }}ToChildren := map[string][]*{{ $c.Type }}{}
	{{- end }}
	{{- end }}

	for _, ch := range children {
		if ch.{{ $c.IDField }} == nil || ch.{{ $c.TypeField }} == nil {
			continue
		}
		switch *ch.{{ $c.TypeField }} {
		{{- range $rc := $c.ResolveCases }}
		case {{ if $c.TypeIsEnum }}{{ $c.IDent }}.{{ $c.TypeField }}(string({{ $rc.MorphConst }})){{ else }}string({{ $rc.MorphConst }}){{ end }}:
			{{- if eq $rc.IDGoType "int" }}
			pid, perr := strconv.Atoi(*ch.{{ $c.IDField }})
			if perr != nil {
				return nil, fmt.Errorf("entpoly: AllWith{{ $c.RelationCap }}: parse {{ $rc.Type }} id %q: %w", *ch.{{ $c.IDField }}, perr)
			}
			{{ $rc.IDent }}IDs = append({{ $rc.IDent }}IDs, pid)
			{{ $rc.IDent }}ToChildren[pid] = append({{ $rc.IDent }}ToChildren[pid], ch)
			{{- else if eq $rc.IDGoType "int64" }}
			pid, perr := strconv.ParseInt(*ch.{{ $c.IDField }}, 10, 64)
			if perr != nil {
				return nil, fmt.Errorf("entpoly: AllWith{{ $c.RelationCap }}: parse {{ $rc.Type }} id %q: %w", *ch.{{ $c.IDField }}, perr)
			}
			{{ $rc.IDent }}IDs = append({{ $rc.IDent }}IDs, pid)
			{{ $rc.IDent }}ToChildren[pid] = append({{ $rc.IDent }}ToChildren[pid], ch)
			{{- else if eq $rc.IDGoType "uuid.UUID" }}
			pid, perr := uuid.Parse(*ch.{{ $c.IDField }})
			if perr != nil {
				return nil, fmt.Errorf("entpoly: AllWith{{ $c.RelationCap }}: parse {{ $rc.Type }} id %q: %w", *ch.{{ $c.IDField }}, perr)
			}
			{{ $rc.IDent }}IDs = append({{ $rc.IDent }}IDs, pid)
			{{ $rc.IDent }}ToChildren[pid] = append({{ $rc.IDent }}ToChildren[pid], ch)
			{{- else }}
			{{ $rc.IDent }}IDs = append({{ $rc.IDent }}IDs, *ch.{{ $c.IDField }})
			{{ $rc.IDent }}ToChildren[*ch.{{ $c.IDField }}] = append({{ $rc.IDent }}ToChildren[*ch.{{ $c.IDField }}], ch)
			{{- end }}
		{{- end }}
		}
	}

	{{- range $rc := $c.ResolveCases }}
	if len({{ $rc.IDent }}IDs) > 0 {
		parents, perr := New{{ $rc.Type }}Client(l.q.config).Query().
			Where({{ $rc.IDent }}.IDIn({{ $rc.IDent }}IDs...){{ if $rc.HasSoftDelete }}, {{ $rc.IDent }}.{{ $rc.SoftDeleteFieldCap }}IsNil(){{ end }}).
			All(ctx)
		if perr != nil {
			return nil, fmt.Errorf("entpoly: AllWith{{ $c.RelationCap }}: batch-load {{ $rc.Type }}: %w", perr)
		}
		for _, p := range parents {
			for _, ch := range {{ $rc.IDent }}ToChildren[p.ID] {
				result.{{ $c.RelationCap }}[ch.ID] = p
			}
		}
	}
	{{- end }}

	return result, nil
}
{{- end }}
{{ end }}

{{- /* ─── Parent-side typed back-refs (Laravel-style accessors) ──── */ -}}
{{ range .Parents }}
{{ if eq .Kind "morphOne" }}
// Query{{ .FieldCap }} returns the single {{ .Target }} polymorphically
// attached to this {{ .ParentName }} via the "{{ .MorphName }}" relation,
// or (nil, nil) when no row matches. Laravel-style accessor — equivalent
// to PHP's:
//
//	$image = $post->image;  // ← Laravel
//	img, err := post.QueryFeaturedImage(ctx)  // ← entpoly
func (p *{{ .ParentName }}) Query{{ .FieldCap }}(ctx context.Context) (*{{ .Target }}, error) {
	res, err := New{{ .Target }}Client(p.config).Query().
		Where(
			{{ .TargetIDent }}.{{ .IDField }}EQ(p.MorphID()),
			{{ .TargetIDent }}.{{ .TypeField }}EQ({{ if .TypeIsEnum }}{{ .TargetIDent }}.{{ .TypeField }}(string(p.MorphKey())){{ else }}string(p.MorphKey()){{ end }}),
		).
		First(ctx)
	if err != nil {
		// IsNotFound is the "no row" case — return (nil, nil) so the
		// caller can null-check without unwrapping the error type. Any
		// other error (driver, context cancel, ...) is propagated.
		if IsNotFound(err) {
			return nil, nil
		}
		return nil, err
	}
	return res, nil
}
{{- end }}
{{ if eq .Kind "morphMany" }}
// Query{{ .FieldCap }} returns a query builder for all {{ .Target }} rows
// polymorphically attached to this {{ .ParentName }} via the
// "{{ .MorphName }}" relation. The query is composable — chain .Where(),
// .Order(), .Limit(), .All(ctx), .First(ctx), etc.
//
//	// Laravel:    $comments = $post->comments;
//	// entpoly:    comments, _ := post.QueryComments().All(ctx)
//	//             page, _    := post.QueryComments().Limit(10).All(ctx)
func (p *{{ .ParentName }}) Query{{ .FieldCap }}() *{{ .Target }}Query {
	return New{{ .Target }}Client(p.config).Query().
		Where(
			{{ .TargetIDent }}.{{ .IDField }}EQ(p.MorphID()),
			{{ .TargetIDent }}.{{ .TypeField }}EQ({{ if .TypeIsEnum }}{{ .TargetIDent }}.{{ .TypeField }}(string(p.MorphKey())){{ else }}string(p.MorphKey()){{ end }}),
		)
}
{{- end }}
{{ end }}

{{- /* ─── Runtime hooks (Required + Touch) ────────────────────────
Polymorphic relations support two opt-in runtime behaviours that need
hook registration to activate:

  - Required()  → rejects Save when the discriminator is missing or
                  being cleared. Fills the "missing value" gap that
                  field.Enum's validator alone does not catch.
  - Touch(field) → bumps the parent's timestamp column on every child
                   Save, Laravel-$touches style.

Both are wired through RegisterPolyHooks(client) which the user calls
once at startup. Without that call, both flags are silently advisory.
*/ -}}
{{ if .HasRequired }}
// errEntPolyRequired is the sentinel returned by every Required()
// enforcement hook. Use errors.Is to detect.
var errEntPolyRequired = errors.New("entpoly: required polymorphic relation missing")
{{ end }}

{{ if .HasPolyHooks }}
// RegisterPolyHooks installs the runtime hooks declared by MorphTo
// builder options (Required, Touch). Call once after creating the
// client, before any writes:
//
//	client := ent.NewClient(...)
//	ent.RegisterPolyHooks(client)
//
// Without this call the options are silently advisory:
//
//   - Required() will NOT reject incomplete writes.
//   - Touch() will NOT bump the parent timestamp.
//
// Hooks run in registration order; Required hooks come first so a
// rejected save short-circuits before any touch fires.
func RegisterPolyHooks(c *Client) {
{{- range .RequiredChildren }}
	c.{{ .Type }}.Use({{ .IDent }}{{ .RelationCap }}RequiredHook())
{{- end }}
{{- range .TouchedChildren }}
	c.{{ .Type }}.Use({{ .IDent }}{{ .RelationCap }}TouchHook())
{{- end }}
{{- /* Cascade hooks land on each ALLOWED PARENT, not on the child:
     they fire when the parent is deleted, deleting the child rows.
     One Use(...) per (child, allowed-parent) pair. */ -}}
{{- range $c := .CascadedChildren }}
{{- range $rc := $c.ResolveCases }}
	c.{{ $rc.Type }}.Use({{ $c.IDent }}{{ $c.RelationCap }}CascadeOn{{ $rc.Type }}DeleteHook())
{{- end }}
{{- end }}
}
{{ end }}

{{ if .HasRequired }}

{{ range .RequiredChildren }}
// {{ .IDent }}{{ .RelationCap }}RequiredHook returns the ent.Hook that enforces
// MorphTo("{{ .Relation }}").Required() at runtime. Wired automatically
// by RegisterPolyHooks; exposed individually so callers can install it
// on a sub-client (e.g. a tx) without registering every hook.
func {{ .IDent }}{{ .RelationCap }}RequiredHook() Hook {
	return func(next Mutator) Mutator {
		return MutateFunc(func(ctx context.Context, m Mutation) (Value, error) {
			cm, ok := m.(*{{ .Type }}Mutation)
			if !ok {
				return next.Mutate(ctx, m)
			}
			switch cm.Op() {
			case OpCreate:
				// On create both columns must be set. Use the
				// generated <Field>() (value, exists) getter.
				_, idOK := cm.{{ .IDField }}()
				_, tyOK := cm.{{ .TypeField }}()
				if !idOK || !tyOK {
					return nil, fmt.Errorf("entpoly: {{ .Type }}.{{ .Relation }} is required — "+
						"call Set{{ .RelationCap }}(parent) before Save: %w", errEntPolyRequired)
				}
			case OpUpdate, OpUpdateOne:
				// On update reject explicit clears of either column.
				if cm.{{ .IDField }}Cleared() || cm.{{ .TypeField }}Cleared() {
					return nil, fmt.Errorf("entpoly: cannot Clear{{ .RelationCap }}() — "+
						"{{ .Type }}.{{ .Relation }} is Required(): %w", errEntPolyRequired)
				}
			}
			return next.Mutate(ctx, m)
		})
	}
}
{{ end }}
{{ end }}

{{- /* ─── Touch hooks ───────────────────────────────────────────── */ -}}
{{ if .HasTouch }}
{{ range $c := .TouchedChildren }}
// {{ $c.IDent }}{{ $c.RelationCap }}TouchHook returns the ent.Hook that
// implements Laravel-$touches semantics for MorphTo("{{ $c.Relation }}").Touch():
// after every successful Save of a {{ $c.Type }}, the polymorphic
// parent's {{ $c.TouchField }} column is bumped to time.Now(). The
// parent update runs in the same logical operation; if it errors the
// child save is reported as failed.
//
// The hook is registered automatically by RegisterPolyHooks. Exposed
// individually so callers can install it on a sub-client (e.g. a tx).
//
// Each allowed parent type must declare a Time field named
// "{{ $c.TouchField }}". A missing field surfaces as an undefined-method
// compile error on Set{{ $c.TouchFieldCap }} below.
func {{ $c.IDent }}{{ $c.RelationCap }}TouchHook() Hook {
	return func(next Mutator) Mutator {
		return MutateFunc(func(ctx context.Context, m Mutation) (Value, error) {
			// Run the child save first — only touch the parent if the
			// child write succeeded. Same ordering Laravel uses.
			v, err := next.Mutate(ctx, m)
			if err != nil {
				return v, err
			}
			cm, ok := m.(*{{ $c.Type }}Mutation)
			if !ok {
				return v, nil
			}
			// On Create the discriminator is in the mutation. On Update
			// the user typically did not re-set it, so fall back to the
			// OldX(ctx) accessor which loads the current row value
			// from the DB. The relation can still be unset (NULL), in
			// which case there is nothing to touch.
			idStr, idOK := cm.{{ $c.IDField }}()
			if !idOK {
				if oldID, oerr := cm.Old{{ $c.IDField }}(ctx); oerr == nil && oldID != nil {
					idStr = *oldID
					idOK = true
				}
			}
			tyVal, tyOK := cm.{{ $c.TypeField }}()
			if !tyOK {
				if oldTy, oerr := cm.Old{{ $c.TypeField }}(ctx); oerr == nil && oldTy != nil {
					tyVal = *oldTy
					tyOK = true
				}
			}
			if !idOK || !tyOK {
				return v, nil // discriminator unset; nothing to touch
			}
			now := time.Now()
			switch string(tyVal) {
			{{- range $rc := $c.ResolveCases }}
			case string({{ $rc.MorphConst }}):
				{{- if eq $rc.IDGoType "int" }}
				pid, perr := strconv.Atoi(idStr)
				if perr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }}: parse id %q: %w", idStr, perr)
				}
				if _, terr := cm.Client().{{ $rc.Type }}.UpdateOneID(pid).Set{{ $c.TouchFieldCap }}(now).Save(ctx); terr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }} id %d: %w", pid, terr)
				}
				{{- else if eq $rc.IDGoType "int64" }}
				pid, perr := strconv.ParseInt(idStr, 10, 64)
				if perr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }}: parse id %q: %w", idStr, perr)
				}
				if _, terr := cm.Client().{{ $rc.Type }}.UpdateOneID(pid).Set{{ $c.TouchFieldCap }}(now).Save(ctx); terr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }} id %d: %w", pid, terr)
				}
				{{- else if eq $rc.IDGoType "uuid.UUID" }}
				pid, perr := uuid.Parse(idStr)
				if perr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }}: parse id %q: %w", idStr, perr)
				}
				if _, terr := cm.Client().{{ $rc.Type }}.UpdateOneID(pid).Set{{ $c.TouchFieldCap }}(now).Save(ctx); terr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }} id %v: %w", pid, terr)
				}
				{{- else }}
				if _, terr := cm.Client().{{ $rc.Type }}.UpdateOneID(idStr).Set{{ $c.TouchFieldCap }}(now).Save(ctx); terr != nil {
					return v, fmt.Errorf("entpoly: touch {{ $rc.Type }} id %q: %w", idStr, terr)
				}
				{{- end }}
			{{- end }}
			}
			return v, nil
		})
	}
}
{{ end }}
{{ end }}

{{- /* ─── Cascade hooks ────────────────────────────────────────────
For every MorphTo declared with .Cascade(), emit a pre-delete hook on
each allowed parent type. The hook reads the parent IDs being deleted,
then deletes every child row whose discriminator points at those
parents. Runs BEFORE the parent delete (matches SQL ON DELETE
CASCADE semantics — children gone first). */ -}}
{{ if .HasCascade }}
{{ range $c := .CascadedChildren }}
{{ range $rc := $c.ResolveCases }}
// {{ $c.IDent }}{{ $c.RelationCap }}CascadeOn{{ $rc.Type }}DeleteHook returns the
// pre-delete hook installed on {{ $rc.Type }} by RegisterPolyHooks when
// MorphTo("{{ $c.Relation }}").Cascade() was declared on {{ $c.Type }}.
// Deletes every {{ $c.Type }} row whose "{{ $c.Relation }}" discriminator
// points at the {{ $rc.Type }} being deleted, in the same logical op.
//
// Polymorphic columns cannot carry FK constraints, so the database
// will not cascade for us; this hook fills the gap. Order matters:
// children are removed BEFORE the parent so no orphan window opens.
func {{ $c.IDent }}{{ $c.RelationCap }}CascadeOn{{ $rc.Type }}DeleteHook() Hook {
	return func(next Mutator) Mutator {
		return MutateFunc(func(ctx context.Context, m Mutation) (Value, error) {
			switch m.Op() {
			case OpDelete, OpDeleteOne:
			default:
				return next.Mutate(ctx, m)
			}
			pm, ok := m.(*{{ $rc.Type }}Mutation)
			if !ok {
				return next.Mutate(ctx, m)
			}
			ids, err := pm.IDs(ctx)
			if err != nil {
				return nil, fmt.Errorf("entpoly: cascade {{ $c.Type }}.{{ $c.Relation }}: enumerate {{ $rc.Type }} ids: %w", err)
			}
			for _, pid := range ids {
				if _, derr := pm.Client().{{ $c.Type }}.Delete().Where(
					{{ $c.IDent }}.{{ $c.TypeField }}EQ({{ if $c.TypeIsEnum }}{{ $c.IDent }}.{{ $c.TypeField }}(string({{ $rc.MorphConst }})){{ else }}string({{ $rc.MorphConst }}){{ end }}),
					{{ $c.IDent }}.{{ $c.IDField }}EQ(fmt.Sprint(pid)),
				).Exec(ctx); derr != nil {
					return nil, fmt.Errorf("entpoly: cascade {{ $c.Type }}.{{ $c.Relation }} for {{ $rc.Type }} id %v: %w", pid, derr)
				}
			}
			return next.Mutate(ctx, m)
		})
	}
}
{{ end }}
{{ end }}
{{ end }}
{{ end }}
